{
  "lock": false,
  "tasks": {
    "bot": "deno run -A --unstable-cron --unstable-kv --watch=telegram/,utils/ bot.ts",
    "start": "deno run -A --unstable-cron --unstable-kv --watch=static/,routes/ dev.ts",
    "build": "deno run -A --unstable-cron --unstable-kv dev.ts build",
    "preview": "deno run -A --unstable-cron --unstable-kv main.ts"
  },
  "compilerOptions": { "jsx": "react-jsx", "jsxImportSource": "preact" },
  "nodeModulesDir": true,
  "imports": {
    "$utils/": "./utils/",
    "$grammy/": "./telegram/",
    "$types/": "./types/",
    "$fluent/": "./fluent/",
    "components/": "./components/",
    "islands/": "./islands/",
    "routes/": "./routes/",
    "$std/": "https://deno.land/std@0.213.0/",
    "$fresh/": "https://deno.land/x/fresh@1.6.5/",
    "preact": "https://esm.sh/preact@10.19.2",
    "preact/": "https://esm.sh/preact@10.19.2/",
    "preact-render-to-string": "https://esm.sh/*preact-render-to-string@6.2.1",
    "@preact/signals": "https://esm.sh/*@preact/signals@1.2.1",
    "@preact/signals-core": "https://esm.sh/*@preact/signals-core@1.5.0",
    "$gfm": "https://deno.land/x/gfm@0.6.0/mod.ts",
    "$fresh_charts/": "https://deno.land/x/fresh_charts@0.3.1/",
    "grammy": "https://deno.land/x/grammy@v1.18.1/mod.ts",
    "grammy_types": "https://deno.land/x/grammy@v1.18.1/types.deno.ts",
    "grammy_parse_mode": "https://deno.land/x/grammy_parse_mode@1.8.1/mod.ts",
    "grammy_menu": "https://deno.land/x/grammy_menu@v1.2.1/mod.ts",
    "grammy_i18n": "https://deno.land/x/grammy_i18n@v1.0.1/mod.ts",
    "grammy_ratelimiter": "https://deno.land/x/grammy_ratelimiter@v1.2.0/mod.ts",
    "grammy_denokv": "https://deno.land/x/grammy_storages@v2.4.0/denokv/src/mod.ts",
    "mongoose": "npm:mongoose@8.0.3",
    "supabase": "npm:@supabase/supabase-js@2.39.1",
    "tailwindcss": "npm:tailwindcss@3.3.5",
    "tailwindcss/": "npm:/tailwindcss@3.3.5/",
    "tailwindcss/plugin": "npm:/tailwindcss@3.3.5/plugin.js",
    "tailwindcss/forms": "npm:/@tailwindcss/forms@0.5.7"
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*"]
}
